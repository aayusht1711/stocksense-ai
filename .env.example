# ── StockSense AI — Environment Config ──────────────────────
# Copy this file to .env and fill in your keys

# Alpha Vantage (free tier: 25 req/day) → https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Reddit API (for WSB sentiment) → https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=StockSenseBot/1.0

# Database (optional — SQLite used by default if not set)
DATABASE_URL=sqlite:///./stocksense.db
# DATABASE_URL=postgresql://user:password@localhost:5432/stocksense

# Redis (optional — in-memory cache used if not set)
REDIS_URL=redis://localhost:6379/0

# App settings
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
LOG_LEVEL=INFO

# Model settings
MODEL_DIR=./models/saved
DATA_DIR=./data/cache
RETRAIN_INTERVAL_HOURS=24
DEFAULT_TICKER=AAPL
DEFAULT_LOOKBACK_DAYS=365
LSTM_SEQUENCE_LENGTH=60
PREDICTION_HORIZON_DAYS=7

# ── Claude AI Chat Assistant ────────────────────────────────
# Get free API key at: console.anthropic.com
# Free tier: 5 req/min, enough for demo use
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Email Alerts (Gmail SMTP) ───────────────────────────────
# Step 1: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Step 2: Create App Password for "Mail" → copy 16-char password
# Step 3: Fill in below (remove spaces from app password)
ALERT_EMAIL_FROM=yourgmail@gmail.com
ALERT_EMAIL_PASSWORD=abcd efgh ijkl mnop
ALERT_EMAIL_TO=where_to_send_alerts@gmail.com

# ── PyTorch ─────────────────────────────────────────────────
# Install: pip install torch  (CPU version, ~250MB)
# GPU version: pip install torch --index-url https://download.pytorch.org/whl/cu118
