# ── StockSense AI — .gitignore ───────────────────────────────

# Secrets — NEVER commit these
.env
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/
ENV/

# Trained model files (too large for GitHub — use Git LFS if needed)
models/saved/*.pkl
models/saved/*.keras
models/saved/*.pt
models/saved/*.h5
models/saved/logs/

# Data cache (regenerated automatically on first run)
data/cache/
data/*.parquet
data/*.csv

# Notebooks checkpoints
.ipynb_checkpoints/
notebooks/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Docker
*.tar

# Zip files
*.zip
